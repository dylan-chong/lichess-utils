{
  "name": "lichess-board-speaker",
  "version": "3.4.7",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "check": "npm run custom-lint && tsc --noEmit",
    "custom-lint": "tsx scripts/customLinter.ts",
    "test": "npm run check && vitest run --coverage",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "prepare": "husky"
  },
  "dependencies": {
    "@preact/signals": "^1.2.0",
    "preact": "^10.19.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@swc/core": "^1.7.0",
    "@testing-library/preact": "^3.2.0",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.9.1",
    "@vitest/coverage-v8": "^2.1.0",
    "@vitest/ui": "^2.1.0",
    "glob": "13.0.6",
    "happy-dom": "^12.10.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "simone": "file:../simone/simone-3.1.0.tgz",
    "tsx": "4.22.4",
    "typescript": "^5.3.0",
    "unplugin-swc": "^1.5.0",
    "vite": "5.0.11",
    "vitest": "^2.1.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "biome check --write",
      "biome format --write"
    ]
  }
}
