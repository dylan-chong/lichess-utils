{
  "name": "lichess-board-speaker",
  "version": "3.4.7",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "check": "tsc --noEmit",
    "test": "npm run check && vitest run --coverage",
    "test:watch": "vitest",
