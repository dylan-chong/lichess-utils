{
  "name": "lichess-board-speaker",
  "version": "4.0.8",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "dev:serve": "python3 -m http.server 8002",
    "build": "vite build",
    "check": "npm run lint && tsc --noEmit",
    "custom-lint": "tsx scripts/customLinter.ts",
    "test": "npm run check && vitest run --coverage",
    "test:watch": "vitest",
    "lint": "biome check src/ && npm run custom-lint",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "prepare": "husky"
  },
  "dependencies": {
    "@preact/signals": "^1.3.4",
    "preact": "^10.29.2",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@swc/core": "^1.15.40",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.9.1",
    "@types/three": "0.184.1",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "glob": "13.0.6",
    "happy-dom": "^20.10.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "simone": "file:../simone/simone-4.0.2.tgz",
    "tsx": "4.22.4",
    "typescript": "^5.9.3",
    "unplugin-swc": "^1.5.9",
    "vite": "8.0.16",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "biome check --write",
      "biome format --write"
    ]
  }
}
