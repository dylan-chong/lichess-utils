  },
  "dependencies": {
    "@preact/signals": "^1.2.0",
    "preact": "^10.19.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@swc/core": "^1.7.0",
    "@testing-library/preact": "^3.2.0",
    "@vitest/ui": "^1.2.0",
    "happy-dom": "^12.10.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "simone": "file:/Users/dylanchong/Development/Other/simone",
    "typescript": "^5.3.0",
    "unplugin-swc": "^1.5.0",
    "vite": "^5.0.0",
    "vitest": "^1.2.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "biome check --write",
      "biome format --write"
    ]
